# Banco de dados
import sqlite3

def conectar():
    conn = sqlite3.connect("motores.db", check_same_thread=False)
    return conn

def criar_tabela():
    conn = conectar()
    cursor = conn.cursor()
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS motores (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            cliente TEXT,
            modelo TEXT,
            potencia TEXT,
            tensao TEXT,
            corrente TEXT,
            rpm TEXT,
            esquema_ligacao TEXT,
            observacoes TEXT
        )
    """)
    conn.commit()
    conn.close()

# Executa a criação da tabela assim que o módulo é importado
criar_tabela()
